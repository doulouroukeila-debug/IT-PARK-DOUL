<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_alert_tree" model="ir.ui.view">
        <field name="name">it.alert.tree</field>
        <field name="model">it.alert</field>
        <field name="arch" type="xml">
            <tree>
                <field name="type"/>
                <field name="equipment_id"/>
                <field name="contract_id"/>
                <field name="date_alert"/>
                <field name="date_event"/>
                <field name="days_before" widget="statinfo"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_it_alert_form" model="ir.ui.view">
        <field name="name">it.alert.form</field>
        <field name="model">it.alert</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_resolve" type="object"
                            string="Résoudre" class="btn-success"
                            states="pending,sent"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,sent,resolved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="equipment_id"/>
                            <field name="contract_id"/>
                        </group>
                        <group>
                            <field name="date_alert"/>
                            <field name="date_event"/>
                            <field name="days_before" readonly="1"/>
                        </group>
                    </group>
                    <field name="message"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_it_alert_search" model="ir.ui.view">
        <field name="name">it.alert.search</field>
        <field name="model">it.alert</field>
        <field name="arch" type="xml">
            <search>
                <field name="equipment_id"/>
                <field name="contract_id"/>
                <filter name="filter_pending" string="En attente"
                        domain="[('state','=','pending')]"/>
                <filter name="filter_warranty" string="Fin de garantie"
                        domain="[('type','=','warranty')]"/>
                <filter name="filter_contract" string="Expiration contrat"
                        domain="[('type','=','contract')]"/>
            </search>
        </field>
    </record>

    <record id="action_it_alert" model="ir.actions.act_window">
        <field name="name">Alertes</field>
        <field name="res_model">it.alert</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Scan alerts action -->
    <record id="action_it_alert_scan" model="ir.actions.act_window">
        <field name="name">Scanner les alertes</field>
        <field name="res_model">it.alert.scan.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_it_alert"/>
        <field name="binding_type">action</field>
    </record>
</odoo>
