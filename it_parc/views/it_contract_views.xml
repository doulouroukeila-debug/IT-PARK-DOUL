<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_contract_tree" model="ir.ui.view">
        <field name="name">it.contract.tree</field>
        <field name="model">it.contract</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="ref"/>
                <field name="supplier_id"/>
                <field name="type"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="days_remaining" widget="statinfo"/>
                <field name="amount"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_it_contract_form" model="ir.ui.view">
        <field name="name">it.contract.form</field>
        <field name="model">it.contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_renew" type="object"
                            string="Renouveler" class="btn-primary"
                            groups="group_it_manager"
                            states="active,expired"/>
                    <button name="action_expire" type="object"
                            string="Marquer expiré"
                            states="active"/>
                    <button name="action_terminate" type="object"
                            string="Résilier"
                            groups="group_it_manager"
                            states="active"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,expired,terminated"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="ref"/>
                            <field name="supplier_id"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="days_remaining" readonly="1"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <field name="notes"/>
                    <field name="equipment_ids"/>
                    <field name="attachment_ids" widget="many2many_binary"
                           string="Documents"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_it_contract_search" model="ir.ui.view">
        <field name="name">it.contract.search</field>
        <field name="model">it.contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="supplier_id"/>
                <field name="ref"/>
                <filter name="filter_active" string="Actifs"
                        domain="[('state','=','active')]"/>
                <filter name="filter_expired" string="Expirés"
                        domain="[('state','=','expired')]"/>
                <filter name="filter_expiring_soon" string="Expirant dans 60 jours"
                        domain="[('days_remaining','&gt;',0),('days_remaining','&lt;=',60)]"/>
                <separator/>
                <filter name="group_type" string="Type"
                        context="{'group_by':'type'}"/>
            </search>
        </field>
    </record>

    <record id="action_it_contract" model="ir.actions.act_window">
        <field name="name">Contrats fournisseurs</field>
        <field name="res_model">it.contract</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
