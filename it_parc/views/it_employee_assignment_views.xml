<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_assignment_tree" model="ir.ui.view">
        <field name="name">it.assignment.tree</field>
        <field name="model">it.assignment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="equipment_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_it_assignment_form" model="ir.ui.view">
        <field name="name">it.assignment.form</field>
        <field name="model">it.assignment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="reason"/>
                    <field name="notes"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_it_assignment_search" model="ir.ui.view">
        <field name="name">it.assignment.search</field>
        <field name="model">it.assignment</field>
        <field name="arch" type="xml">
            <search>
                <field name="equipment_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <filter name="filter_active" string="Actives"
                        domain="[('state','=','active')]"/>
            </search>
        </field>
    </record>

    <record id="action_it_assignment" model="ir.actions.act_window">
        <field name="name">Affectations</field>
        <field name="res_model">it.assignment</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
