<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="Dashboard" name="IT Parc Dashboard">
        <div class="o_dashboard" style="padding: 20px;">
            <div t-if="state.loading" class="text-center">
                <i class="fa fa-spinner fa-spin fa-3x"/>
                <p>Chargement du tableau de bord...</p>
            </div>
            <div t-elif="state.error" class="alert alert-danger">
                Erreur lors du chargement des données du tableau de bord.
            </div>
            <div t-else="">
                <h2 class="mb-4">Tableau de bord - Parc Informatique</h2>

                <!-- Ligne 1 des KPIs -->
                <div class="row mb-4">
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card text-white bg-primary">
                            <div class="card-body text-center">
                                <h5 class="card-title">Total équipements</h5>
                                <h1 class="display-4"><t t-esc="state.data.total_equipments"/></h1>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card text-white bg-success">
                            <div class="card-body text-center">
                                <h5 class="card-title">Affectés</h5>
                                <h1 class="display-4"><t t-esc="state.data.assigned_equipments"/></h1>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card text-white bg-warning">
                            <div class="card-body text-center">
                                <h5 class="card-title">En maintenance</h5>
                                <h1 class="display-4"><t t-esc="state.data.maintenance_equipments"/></h1>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card text-white bg-danger">
                            <div class="card-body text-center">
                                <h5 class="card-title">Alertes en attente</h5>
                                <h1 class="display-4"><t t-esc="state.data.pending_alerts"/></h1>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Ligne 2 des KPIs -->
                <div class="row mb-4">
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card text-white bg-info">
                            <div class="card-body text-center">
                                <h5 class="card-title">Interventions (année)</h5>
                                <h1 class="display-4"><t t-esc="state.data.interventions_this_year"/></h1>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card text-white bg-secondary">
                            <div class="card-body text-center">
                                <h5 class="card-title">Coût maintenance (année)</h5>
                                <h1 class="h3"><t t-esc="state.data.total_maintenance_cost"/> FCFA</h1>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card text-white bg-dark">
                            <div class="card-body text-center">
                                <h5 class="card-title">Valeur du parc</h5>
                                <h1 class="h3"><t t-esc="state.data.total_asset_value"/> FCFA</h1>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                        <div class="card border-primary">
                            <div class="card-body text-center">
                                <h5 class="card-title">Contrats actifs</h5>
                                <h1 class="display-4"><t t-esc="state.data.active_contracts"/></h1>
                                <small class="text-muted">
                                    <t t-esc="state.data.expiring_contracts"/> expirent bientôt
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tableaux -->
                <div class="row">
                    <div class="col-lg-6 mb-4">
                        <div class="card">
                            <div class="card-header"><strong>Équipements par état</strong></div>
                            <div class="card-body">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>État</th>
                                            <th>Nombre</th>
                                            <th>%</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="state.data.equipments_by_state" t-as="key">
                                            <td t-esc="key"/>
                                            <td><strong t-esc="state.data.equipments_by_state[key]"/></td>
                                            <td t-esc="(state.data.total_equipments > 0 and (state.data.equipments_by_state[key] / state.data.total_equipments * 100).toFixed(1) or 0) + '%'"/>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 mb-4">
                        <div class="card">
                            <div class="card-header"><strong>Équipements par catégorie</strong></div>
                            <div class="card-body">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Catégorie</th>
                                            <th>Nombre</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="state.data.equipments_by_category" t-as="key">
                                            <td t-esc="key"/>
                                            <td><strong t-esc="state.data.equipments_by_category[key]"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Graphique à barres -->
                <div class="row">
                    <div class="col-12 mb-4">
                        <div class="card">
                            <div class="card-header"><strong>Répartition par catégorie</strong></div>
                            <div class="card-body">
                                <t t-set="colors" t-value="['#0066CC','#28a745','#ffc107','#dc3545','#17a2b8','#6c757d','#343a40','#007bff']"/>
                                <t t-foreach="state.data.equipments_by_category" t-as="key">
                                    <t t-set="idx" t-value="key_index"/>
                                    <t t-set="pct" t-value="state.data.total_equipments > 0 ? (state.data.equipments_by_category[key] / state.data.total_equipments * 100).toFixed(1) : 0"/>
                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between">
                                            <span t-esc="key"/>
                                            <span t-esc="state.data.equipments_by_category[key]"/>
                                        </div>
                                        <div class="progress" style="height: 25px;">
                                            <div class="progress-bar" t-attf-style="width: {{ pct }}%; background-color: {{ colors[idx % colors.length] }};">
                                                <t t-esc="pct"/>%
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>
