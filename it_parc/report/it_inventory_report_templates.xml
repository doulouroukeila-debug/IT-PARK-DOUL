<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_it_inventory" model="ir.actions.report">
        <field name="name">Inventaire complet</field>
        <field name="model">it.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_it_inventory</field>
        <field name="report_file">it_parc.report_it_inventory</field>
        <field name="binding_model_id" ref="model_it_equipment"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_it_inventory">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page">
                    <h2>Rapport d'inventaire du parc informatique</h2>
                    <p>
                        Généré le <span t-esc="datetime.now().strftime('%d/%m/%Y %H:%M')"/>
                        <t t-if="data and data.get('department_id')">
                            - Département: <span t-esc="data['department_id']"/>
                        </t>
                        <t t-if="data and data.get('category')">
                            - Catégorie: <span t-esc="data['category']"/>
                        </t>
                    </p>

                    <p><strong>Total équipements:</strong> <span t-esc="len(docs)"/></p>

                    <table class="table table-bordered" style="width:100%">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Nom</th>
                                <th>Catégorie</th>
                                <th>Marque</th>
                                <th>Employé</th>
                                <th>Département</th>
                                <th>État</th>
                                <th>Valeur</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="doc">
                                <td t-esc="doc.code"/>
                                <td t-esc="doc.name"/>
                                <td t-esc="dict(doc._fields['category'].selection).get(doc.category)"/>
                                <td t-esc="doc.brand or ''"/>
                                <td t-esc="doc.employee_id.name or ''"/>
                                <td t-esc="doc.department_id.name or ''"/>
                                <td t-esc="dict(doc._fields['state'].selection).get(doc.state)"/>
                                <td t-esc="doc.purchase_value" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </tr>
                        </tbody>
                    </table>

                    <p>
                        <strong>Valeur totale du parc:</strong>
                        <span t-esc="sum(docs.mapped('purchase_value'))"/>
                    </p>
                </div>
            </t>
        </t>
    </template>
</odoo>
