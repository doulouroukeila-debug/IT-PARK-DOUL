<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_it_equipment" model="ir.actions.report">
        <field name="name">Fiche équipement</field>
        <field name="model">it.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_it_equipment</field>
        <field name="report_file">it_parc.report_it_equipment</field>
        <field name="binding_model_id" ref="model_it_equipment"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_it_equipment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.internal_layout">
                    <div class="page">
                        <h2>Fiche d'équipement</h2>
                        <table class="table table-bordered" style="width:100%">
                            <tr>
                                <td><strong>Code interne</strong></td>
                                <td t-esc="doc.code"/>
                            </tr>
                            <tr>
                                <td><strong>Nom</strong></td>
                                <td t-esc="doc.name"/>
                            </tr>
                            <tr>
                                <td><strong>Catégorie</strong></td>
                                <td t-esc="dict(doc._fields['category'].selection).get(doc.category)"/>
                            </tr>
                            <tr>
                                <td><strong>Marque</strong></td>
                                <td t-esc="doc.brand or ''"/>
                            </tr>
                            <tr>
                                <td><strong>Modèle</strong></td>
                                <td t-esc="doc.model or ''"/>
                            </tr>
                            <tr>
                                <td><strong>N° de série</strong></td>
                                <td t-esc="doc.serial_number or ''"/>
                            </tr>
                            <tr>
                                <td><strong>N° d'inventaire</strong></td>
                                <td t-esc="doc.asset_number or ''"/>
                            </tr>
                            <tr>
                                <td><strong>Valeur d'achat</strong></td>
                                <td t-esc="doc.purchase_value" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </tr>
                            <tr>
                                <td><strong>Date d'achat</strong></td>
                                <td t-esc="doc.purchase_date"/>
                            </tr>
                            <tr>
                                <td><strong>Fin de garantie</strong></td>
                                <td t-esc="doc.warranty_date"/>
                            </tr>
                            <tr>
                                <td><strong>État</strong></td>
                                <td t-esc="dict(doc._fields['state'].selection).get(doc.state)"/>
                            </tr>
                            <tr>
                                <td><strong>Employé</strong></td>
                                <td t-esc="doc.employee_id.name or 'Non affecté'"/>
                            </tr>
                            <tr>
                                <td><strong>Département</strong></td>
                                <td t-esc="doc.department_id.name or ''"/>
                            </tr>
                            <tr>
                                <td><strong>Localisation</strong></td>
                                <td t-esc="doc.location or ''"/>
                            </tr>
                        </table>

                        <h3>Caractéristiques techniques</h3>
                        <p t-esc="doc.technical_specs or 'Aucune'"/>

                        <h3>Interventions récentes</h3>
                        <table class="table table-bordered" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Titre</th>
                                    <th>Technicien</th>
                                    <th>Coût</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.intervention_ids[:10]" t-as="intv">
                                    <td t-esc="intv.date_start"/>
                                    <td t-esc="dict(intv._fields['type'].selection).get(intv.type)"/>
                                    <td t-esc="intv.title"/>
                                    <td t-esc="intv.technician_id.name"/>
                                    <td t-esc="intv.cost" t-options="{'widget': 'monetary', 'display_currency': intv.currency_id}"/>
                                </tr>
                                <tr t-if="not doc.intervention_ids">
                                    <td colspan="5">Aucune intervention</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
