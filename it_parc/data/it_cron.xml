<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_it_alert_scan" model="ir.cron">
            <field name="name">Scan automatique des alertes</field>
            <field name="model_id" ref="model_it_alert"/>
            <field name="state">code</field>
            <field name="code">model.scan_alerts()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <!-- Paramètre configurable pour le délai d'alerte -->
        <record id="param_alert_days_before" model="ir.config_parameter">
            <field name="key">it_parc.alert_days_before</field>
            <field name="value">30</field>
        </record>
    </data>
</odoo>
