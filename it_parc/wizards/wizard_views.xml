<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reassign wizard -->
    <record id="view_it_reassign_wizard_form" model="ir.ui.view">
        <field name="name">it.reassign.wizard.form</field>
        <field name="model">it.reassign.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="equipment_id"/>
                    <field name="employee_id"/>
                    <field name="date_start"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirmer"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Renew contract wizard -->
    <record id="view_it_renew_contract_wizard_form" model="ir.ui.view">
        <field name="name">it.renew.contract.wizard.form</field>
        <field name="model">it.renew.contract.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="contract_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="amount"/>
                    <field name="notes"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Créer le renouvellement"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Alert scan wizard -->
    <record id="view_it_alert_scan_wizard_form" model="ir.ui.view">
        <field name="name">it.alert.scan.wizard.form</field>
        <field name="model">it.alert.scan.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <p>Ce scan va vérifier les garanties et contrats arrivant à expiration.</p>
                </group>
                <group>
                    <field name="alert_count" invisible="state == 'start'"/>
                    <field name="state" invisible="1"/>
                </group>
                <footer>
                    <button name="action_scan" string="Lancer le scan"
                            type="object" class="btn-primary"
                            states="start"/>
                    <button name="action_close" string="Fermer"
                            type="object" class="btn-primary"
                            states="result"/>
                    <button string="Annuler" class="btn-secondary"
                            special="cancel" states="start"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- CSV import wizard -->
    <record id="view_it_csv_import_wizard_form" model="ir.ui.view">
        <field name="name">it.csv.import.wizard.form</field>
        <field name="model">it.csv.import.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group states="choose">
                    <field name="file" filename="filename" required="1"/>
                    <field name="filename" invisible="1"/>
                    <p>Format CSV attendu : name, serial_number, category, brand, model, asset_number, location, purchase_value, purchase_date, warranty_date, technical_specs</p>
                </group>
                <group states="result">
                    <field name="line_ids">
                        <tree>
                            <field name="line_content"/>
                            <field name="status" widget="badge"
                                   decoration-success="status == 'success'"
                                   decoration-warning="status == 'warning'"
                                   decoration-danger="status == 'error'"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button name="action_import" string="Importer"
                            type="object" class="btn-primary"
                            states="choose"/>
                    <button name="action_close" string="Fermer"
                            type="object" class="btn-primary"
                            states="result"/>
                    <button string="Annuler" class="btn-secondary"
                            special="cancel" states="choose"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_it_csv_import" model="ir.actions.act_window">
        <field name="name">Import CSV</field>
        <field name="res_model">it.csv.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
