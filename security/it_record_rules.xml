<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_it_equipment_technician_readonly" model="ir.rule">
            <field name="name">IT Equipment: Technician read-only</field>
            <field name="model_id" ref="model_it_equipment"/>
            <field name="groups" eval="[(4, ref('group_it_technician'))]"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_it_intervention_technician_own" model="ir.rule">
            <field name="name">IT Intervention: Technician own records</field>
            <field name="model_id" ref="model_it_intervention"/>
            <field name="groups" eval="[(4, ref('group_it_technician'))]"/>
            <field name="domain_force">[('technician_id.user_id', '=', user.id)]</field>
        </record>

        <record id="rule_it_contract_technician_readonly" model="ir.rule">
            <field name="name">IT Contract: Technician read-only</field>
            <field name="model_id" ref="model_it_contract"/>
            <field name="groups" eval="[(4, ref('group_it_technician'))]"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
