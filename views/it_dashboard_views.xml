<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_it_dashboard" model="ir.actions.act_window">
        <field name="name">Tableau de bord</field>
        <field name="res_model">it.equipment</field>
        <field name="view_mode">list</field>
        <field name="views" eval="[[False, 'tree']]"/>
        <field name="help" type="html">
            <p>Tableau de bord du parc informatique.</p>
        </field>
    </record>

    <record id="action_it_dashboard_owl" model="ir.actions.client">
        <field name="name">Tableau de bord IT</field>
        <field name="tag">it_parc_dashboard</field>
    </record>

    <record id="view_dashboard_menu_form" model="ir.ui.view">
        <field name="name">it.dashboard.menu.form</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <sheet/>
            </form>
        </field>
    </record>
</odoo>
