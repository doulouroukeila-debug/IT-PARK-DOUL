<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_assignment_tree" model="ir.ui.view">
        <field name="name">it.assignment.tree</field>
        <field name="model">it.assignment</field>
        <field name="arch" type="xml">
            <list string="Affectations" editable="top">
                <field name="equipment_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="assignment_date"/>
                <field name="end_date"/>
                <field name="reason"/>
                <field name="state" decoration-success="state == 'active'" decoration-muted="state == 'ended'"/>
            </list>
        </field>
    </record>

    <record id="view_it_assignment_form" model="ir.ui.view">
        <field name="name">it.assignment.form</field>
        <field name="model">it.assignment</field>
        <field name="arch" type="xml">
            <form string="Affectation">
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="action_terminate" string="Terminer l'affectation" type="object" invisible="state != 'active'" class="btn-danger"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="assignment_date"/>
                            <field name="end_date"/>
                            <field name="reason"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_assignment" model="ir.actions.act_window">
        <field name="name">Affectations</field>
        <field name="res_model">it.assignment</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Consultez l'historique des affectations des équipements aux employés.</p>
        </field>
    </record>
</odoo>
