<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_scan_alert_wizard_form" model="ir.ui.view">
        <field name="name">it.scan.alert.wizard.form</field>
        <field name="model">it.scan.alert.wizard</field>
        <field name="arch" type="xml">
            <form string="Scan des alertes">
                <group invisible="state != 'choose'">
                    <field name="days_ahead"/>
                </group>
                <group invisible="state != 'result'">
                    <field name="result" readonly="1" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_scan" string="Lancer le scan" type="object" class="btn-primary" invisible="state != 'choose'"/>
                    <button string="Fermer" class="btn-secondary" special="cancel" invisible="state != 'result'"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
