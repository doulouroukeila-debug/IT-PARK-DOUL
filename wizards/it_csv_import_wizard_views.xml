<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_csv_import_wizard_form" model="ir.ui.view">
        <field name="name">it.csv.import.wizard.form</field>
        <field name="model">it.csv.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import CSV">
                <group>
                    <field name="file" filename="filename" required="1"/>
                    <field name="filename" invisible="1"/>
                </group>
                <group>
                    <field name="report" readonly="1" colspan="2" invisible="report == ''"/>
                </group>
                <footer>
                    <button name="action_import" string="Importer" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
