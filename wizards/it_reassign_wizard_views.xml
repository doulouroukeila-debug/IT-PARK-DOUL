<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_reassign_wizard_form" model="ir.ui.view">
        <field name="name">it.reassign.wizard.form</field>
        <field name="model">it.reassign.wizard</field>
        <field name="arch" type="xml">
            <form string="Réaffectation d'équipement">
                <group>
                    <field name="equipment_id" readonly="1"/>
                    <field name="employee_id" options="{'no_create': True}" required="1"/>
                    <field name="department_id" options="{'no_create': True}" required="1"/>
                    <field name="assignment_date" required="1"/>
                    <field name="reason" required="1"/>
                </group>
                <footer>
                    <button name="action_reassign" string="Confirmer l'affectation" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_reassign_wizard" model="ir.actions.act_window">
        <field name="name">Réaffecter</field>
        <field name="res_model">it.reassign.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
